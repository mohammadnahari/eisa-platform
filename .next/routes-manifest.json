      "regex": "^/api/auth/callback(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/callback(?:/)?$"
    },
    {
      "page": "/api/stripe/webhook",
      "regex": "^/api/stripe/webhook(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/stripe/webhook(?:/)?$"
    },
    {
      "page": "/client",
      "regex": "^/client(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/client(?:/)?$"
    },
    {
      "page": "/client/goals",
      "regex": "^/client/goals(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/client/goals(?:/)?$"
